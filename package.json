{
    "name": "@hlf-core/transport-chaincode",
    "version": "3.6.8",
    "description": "TypeScript library for Hyperledger Fabric transport on the chaincode side: command receiving, signature and nonce validation, batch processing and event dispatching",
    "main": "./cjs/public-api.js",
    "module": "./esm/public-api.js",
    "exports": {
        ".": {
            "import": "./esm/public-api.js",
            "require": "./cjs/public-api.js"
        }
    },
    "author": {
        "name": "Renat Gubaev",
        "email": "renat.gubaev@gmail.com"
    },
    "license": "ISC",
    "dependencies": {
        "@hlf-core/chaincode": "~3.6.2",
        "@hlf-core/transport-common": "~3.0.15"
    },
    "devDependencies": {
        "gulp-npm-module-publisher": "~3.0.5"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/ManhattanDoctor/hlf-core-transport-chaincode"
    },
    "keywords": [
        "hyperledger",
        "hyperledger-fabric",
        "fabric",
        "chaincode",
        "transport",
        "smart-contracts",
        "blockchain",
        "distributed-ledger",
        "signature",
        "typescript"
    ],
    "bugs": {
        "url": "https://github.com/ManhattanDoctor/hlf-core-transport-chaincode/issues"
    },
    "homepage": "https://github.com/ManhattanDoctor/hlf-core-transport-chaincode#readme"
}
